asih"],["id","Tremakasih"],["id","Assalamualaikum assalamuaikum Asalamualaikum Assalammualaikum Assalamuallaikum Assalamualikum Assalamualakum Assalmu'alaikum Asalamu'alaikum Assalammualikum Assalamuailakum Assalamulaikum"],["id","Ass"],["id","Assalamualaikum warahmatullahi wabarakatuh"],["id","tanya"],["id","Bertanya"],["id","info"],["id","Informasi"],["id","Tanya"],["id","Pertanyaan"],["id","Pertanya"],["id","Jadwal"],["id","informasi ketersediaan kamar"],["id","visi"],["id","misi"],["id","layanan"],["id","Fasilitas"],["id","pengaduan"],["id","laporan"],["id","Lapor"],["id","mengaduan"],["id","melapor"],["id","mendaftar"],["id","daftar"],["id","Registrasi"],["id","regis"],["id","Sampai jumpa"],["id","Bye"],["id","Dadah"],["id","gak ada"],["id","tidak"]]},"ner":{"settings":{"tag":"ner","entityPreffix":"%","entitySuffix":"%"},"rules":{}},"nlgManager":{"settings":{"tag":"nlg-manager"},"responses":{"id":{"greeting":[{"answer":"Halo!"},{"answer":"Hai!"},{"answer":"Halo, ada yang bisa saya bantu?"}],"ping":[{"answer":"pong"},{"answer":"p!"},{"answer":"Halo, ada yang bisa saya bantu?"}],"salam Pagi":[{"answer":"Selamat Pagi"},{"answer":"Pagi, ada apa yang bisa saya bantu?"}],"salam.Siang":[{"answer":"Selamat Siang"},{"answer":"Siang, ada apa yang bisa saya bantu?"}],"salam.Malam":[{"answer":"Selamat Malam"},{"answer":"Selamat Malam, ada apa yang bisa saya bantu?"}],"salam.ok":[{"answer":"Oke,"},{"answer":"sipp"}],"Teimakasih":[{"answer":"Sama-sama! 😊"},{"answer":"Sama-sama, ada apa yang bisa saya bantu?"}],"Salam":[{"answer":"wa'alaikumussalam wa rahmatullahi wa barakatuh"},{"answer":"wa'alaikumussalam, ada apa yang bisa saya bantu?"}],"question":[{"answer":"Apa yang bisa saya bantu?\n\n1. Informasi ketersediaan kamar?\n2. Jadwal dokter?\nBalas dengan angka 1 atau 2."},{"answer":"Halo! Ada yang bisa saya bantu?\n\n1. Cek ketersediaan kamar\n2. Lihat jadwal dokter\nSilakan balas dengan 1 atau 2."},{"answer":"Selamat datang! Butuh bantuan?\n\n1. Info kamar tersedia\n2. Jadwal dokter\nBalas dengan angka 1 atau 2."},{"answer":"Hai! Bagaimana saya bisa membantu?\n\n1. Cek kamar kosong\n2. Lihat jadwal dokter\nKetik 1 atau 2 untuk memilih."},{"answer":"Butuh informasi?\n\n1. Ketersediaan kamar\n2. Jadwal dokter\nSilakan ketik angka 1 atau 2 untuk respon."},{"answer":"Halo! Apa yang ingin Anda ketahui?\n\n1. Ketersediaan kamar kosong\n2. Jadwal dokter hari ini\nBalas dengan angka 1 atau 2."},{"answer":"Selamat datang! Pilih opsi yang Anda butuhkan:\n\n1. Cek kamar yang tersedia\n2. Lihat jadwal dokter\nKetik 1 atau 2 untuk melanjutkan."},{"answer":"Halo! Saya siap membantu.\n\n1. Ingin tahu kamar yang tersedia?\n2. Perlu informasi jadwal dokter?\nBalas dengan angka 1 atau 2."},{"answer":"Apa yang bisa saya bantu hari ini?\n\n1. Info kamar kosong\n2. Jadwal dokter\nSilakan ketik 1 atau 2."},{"answer":"Halo! Silakan pilih informasi yang Anda butuhkan:\n\n1. Ketersediaan kamar\n2. Jadwal dokter\nKetik angka 1 atau 2 untuk mendapatkan informasi."}],"question.visiMisi":[{"answer":"Menjadi Rumah Sakit Pendidikan Yang Berkualitas , Mandiri Dan Berinovasi Dengan Mengutamakan Keselamatan Pasien Tahun 2027"}],"question.layanan":[{"answer":"1. Laboratorium\n2. Ruang Operasi\n3. Rawat Inap\n4. Rawat Jalan\n5. Rawat Darurat"},{"answer":"Untuk mengetahui layanan rsud bisa kunjungi https://kainraja.rsudaa.singkawangkota.go.id"}],"question.pengaduan":[{"answer":"Terima kasih atas laporan Anda. Kami akan segera memproses laporan Anda."},{"answer":"Baik, untuk lebih lanjut bisa hubungi kami RSUD Abdul Aziz di 0812-2333-9999"}],"register":[{"answer":"Apakah sudah pernah berobat di sini sebelumnya? \nbalaskan dengan angka Ya atau Tidak"},{"answer":"Apakah Anda sudah pernah berobat di sini sebelumnya? \nSilakan balas dengan Ya atau Tidak."},{"answer":"Sebelumnya, apakah Anda pernah menjalani pengobatan di sini? \nSilakan balas dengan Ya atau Tidak."}],"goodbye":[{"answer":"Sampai jumpa!"},{"answer":"Bye, semoga harimu menyenangkan!"}]}}},"actionManager":{"settings":{"tag":"action-manager"},"actions":{}},"slotManager":{}}